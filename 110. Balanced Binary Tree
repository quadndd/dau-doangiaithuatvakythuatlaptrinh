# Definition for a binary tree node.
# class TreeNode(object):
#     def __init__(self, val=0, left=None, right=None):
#         self.val = val
#         self.left = left
#         self.right = right
class Solution(object):
    def isBalanced(self, root):
        """
        :type root: Optional[TreeNode]
        :rtype: bool
        """
        def traversal(root):
            if root is None:
                return True,0
            left_b,left_h=traversal(root.left)
            if not left_b:
                return False,0
            right_b,right_h=traversal(root.right)
            if not right_b:
                return False,0
            height=1+max(left_h,right_h)
            var=True
            if abs(left_h-right_h)>1:
                var=False
            return var,height
        b,h=traversal(root)
        return b